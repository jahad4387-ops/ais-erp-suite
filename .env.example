# 数据库配置
DATABASE_URL="file:./dev.db"
AIS_PLATFORM_STORE="memory" # memory | prisma

# AI/Agent 配置
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."

# 附件存储
AIS_ATTACHMENT_STORAGE_PROVIDER="local" # local | external
AIS_ATTACHMENT_STORAGE_ROOT="./data/attachments"
# Required when AIS_ATTACHMENT_STORAGE_PROVIDER=external in production-like deployments.
AIS_ATTACHMENT_EXTERNAL_ENDPOINT=""
AIS_ATTACHMENT_EXTERNAL_BUCKET=""
AIS_ATTACHMENT_EXTERNAL_CREDENTIAL_REF="" # env:ENV_VAR sends Authorization: Bearer $ENV_VAR; header:x-api-key=env:ENV_VAR sends a custom header.
AIS_ATTACHMENT_EXTERNAL_TOKEN=""
AIS_ATTACHMENT_EXTERNAL_API_KEY=""
AIS_ATTACHMENT_RETENTION_DAYS=""

# 服务端口
API_PORT=3000
AI_WORKER_PORT=3001

# 安全配置
AIS_JWT_SECRET="change-me-in-real-deployments"
# Comma-separated old secrets accepted during JWT rotation grace windows.
AIS_JWT_PREVIOUS_SECRETS=""
# Required when AIS_JWT_PREVIOUS_SECRETS is set in production-like deployments.
AIS_JWT_ROTATION_APPROVED_BY=""
AIS_JWT_ROTATION_EXPIRES_AT=""
AIS_JWT_ROTATION_MONITOR_REF=""
AIS_JWT_ROTATION_ROLLBACK_REF=""

# Initial administrator seed
AIS_ADMIN_USERNAME="admin"
AIS_ADMIN_NAME="System Administrator"
# Generate with: cd packages/database; $env:AIS_ADMIN_PASSWORD='...'; npm run admin:hash
AIS_ADMIN_PASSWORD_HASH="sha256:<salt>:<digest>"

# 部署模式
AIS_DEPLOYMENT_MODE="local" # local | private-cloud | saas
# Backward-compatible alias accepted by the runtime:
DEPLOYMENT_MODE="local"
