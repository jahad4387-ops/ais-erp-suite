  candidates AgentDraftCandidate[]

  @@index([accountSetId, status])
  @@index([accountSetId, draftType])
  @@index([createdAt])
}

model AgentDraftCandidate {
  id                        String   @id @default(uuid())
  accountSetId              String
  fiscalPeriodId            String?
  draftType                 String
  sourceObjectType          String?
  sourceObjectId            String?
  userInstruction           String
  status                    String
  dryRun                    Boolean  @default(true)
  riskLevel                 String
  requiresHumanConfirmation Boolean  @default(true)
  confidence                Float    @default(0)
  sourceContextJson         String   @default("{}")
  matchedMasterDataJson     String   @default("[]")
  unmatchedItemsJson        String   @default("[]")
  draftPayloadJson          String
  ocrResultsJson            String   @default("[]")
  dryRunResultJson          String   @default("{}")
  warningsJson              String   @default("[]")
  evidenceRefsJson          String   @default("[]")
  llmDraftRunId             String?
  createdBy                 String
  createdAt                 DateTime @default(now())
  reviewedBy                String?
  reviewedAt                DateTime?
  rejectedBy                String?
  rejectedAt                DateTime?
  rejectionReason           String?
  convertedObjectType       String?
  convertedObjectId         String?
  resolvedUnmatchedItemsJson String  @default("[]")

  accountSet   AccountSet   @relation(fields: [accountSetId], references: [id])
  llmDraftRun  LlmDraftRun? @relation(fields: [llmDraftRunId], references: [id])

  @@index([accountSetId, status])
  @@index([accountSetId, draftType])
  @@index([llmDraftRunId])
}

model AgentAction {
  id                        String   @id @default(uuid())
  accountSetId              String
  toolName                  String
  dryRun                    Boolean  @default(true)
  riskLevel                 String
  actionKind                String
  status                    String
  approvalRequired          Boolean  @default(false)
  approvalPolicyJson        String   @default("{}")
  evidenceRefsJson          String   @default("[]")
  evidenceSnapshotsJson     String   @default("[]")
  payloadJson               String   @default("{}")
  requestedBy               String
  createdAt                 DateTime @default(now())
  dryRunResultJson          String   @default("{}")
  approvalRequestJson       String?
  approvalProgressJson      String   @default("{}")
  executionResultJson       String?
  reversalResultJson        String?

  accountSet AccountSet @relation(fields: [accountSetId], references: [id])
  approvals  AgentApproval[]
  replayEvents AgentReplayEvent[]
  productionPlans ProductionPlan[]

  @@index([accountSetId, status])
  @@index([accountSetId, riskLevel])
  @@index([toolName])
}

model AgentApproval {
  id                 String   @id @default(uuid())
  agentActionId      String
  approvedBy         String
  approvedAt         DateTime @default(now())
  approvalComment    String?

  agentAction AgentAction @relation(fields: [agentActionId], references: [id])

  @@index([agentActionId, approvedBy])
}

model AgentReplayEvent {
  id            String   @id @default(uuid())
  agentActionId String
  eventType     String
  actorId       String
  payloadJson   String   @default("{}")
  createdAt     DateTime @default(now())

  agentAction AgentAction @relation(fields: [agentActionId], references: [id])

  @@index([agentActionId, createdAt])
}

model SecurityEvent {
  id           String   @id @default(uuid())
  accountSetId String?
  eventType    String
  severity     String
  actorId      String?
  source       String
  objectType   String?
  objectId     String?
  message      String
  payloadJson  String   @default("{}")
  createdAt    DateTime @default(now())

  accountSet AccountSet? @relation(fields: [accountSetId], references: [id], onDelete: SetNull)

  @@index([accountSetId, createdAt])
  @@index([eventType, severity])
  @@index([actorId, createdAt])
}
