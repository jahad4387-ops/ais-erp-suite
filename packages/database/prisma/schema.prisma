generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AccountSet {
  id                 String   @id @default(uuid())
  code               String   @unique
  name               String
  companyName        String
  baseCurrency       String
  accountingStandard String
  startYear          Int
  startPeriod        Int
  status             String
  createdBy          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users              AccountSetUser[]
  periods            AccountingPeriod[]
  accountCodeRules   AccountCodeRule[]
  accounts           ChartOfAccount[]
  auxiliaryTypes     AuxiliaryType[]
  auxiliaryItems     AuxiliaryItem[]
  vouchers           Voucher[]
  attachments        Attachment[]
  postingBatches     PostingBatch[]
  journalEntries     JournalEntry[]
  balances           AccountPeriodBalance[]
  auditLogs          AuditLog[]
  bankStatements     BankStatement[]
  bankRules          BankReconciliationRule[]
  reconciliations    BankReconciliation[]
  partners           Partner[]
  purchaseOrders     PurchaseOrder[]
  salesOrders        SalesOrder[]
  purchaseReceipts   PurchaseReceipt[]
  salesDeliveries    SalesDelivery[]
  purchaseInvoices   PurchaseInvoice[]
  salesInvoices      SalesInvoice[]
  counterpartyLedgerEntries CounterpartyLedgerEntry[]
  paymentRequests    PaymentRequest[]
  supplierPayments   SupplierPayment[]
  customerReceipts   CustomerReceipt[]
  collectionPlans    CollectionPlan[]
  apSettlements      ApSettlement[]
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  passwordHash String
  name      String
  status    String   @default("active")
  createdAt DateTime @default(now())

  accountSets AccountSetUser[]
  userRoles   UserRole[]
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id          String  @id @default(uuid())
  code        String  @unique
  description String?

  rolePermissions RolePermission[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model AccountSetUser {
  accountSetId String
  userId       String
  grantedBy    String?
  grantedAt    DateTime @default(now())

  accountSet AccountSet @relation(fields: [accountSetId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@id([accountSetId, userId])
}

model AccountingPeriod {
  id           String   @id @default(uuid())
  accountSetId String
  fiscalYear   Int
  periodNo     Int
  startDate    DateTime
  endDate      DateTime
  status       String
  isCurrent    Boolean  @default(false)

  accountSet AccountSet @relation(fields: [accountSetId], references: [id])
  vouchers   Voucher[]

  @@unique([accountSetId, fiscalYear, periodNo])
}

model AccountCodeRule {
  id           String   @id @default(uuid())
  accountSetId String
  segmentsJson String
  createdAt    DateTime @default(now())

  accountSet AccountSet @relation(fields: [accountSetId], references: [id])

  @@unique([accountSetId])
}

model ChartOfAccount {
  id               String   @id @default(uuid())
  accountSetId     String
  code             String
  name             String
  parentId         String?
  level            Int
  accountType      String
  normalBalance    String
  isLeaf           Boolean  @default(true)
  isCash           Boolean  @default(false)
  isBank           Boolean  @default(false)
  isEnabled        Boolean  @default(true)
  allowManualEntry Boolean  @default(true)
  createdAt        DateTime @default(now())

  accountSet            AccountSet                    @relation(fields: [accountSetId], references: [id])
  parent                ChartOfAccount?               @relation("AccountParentChild", fields: [parentId], references: [id])
  children              ChartOfAccount[]              @relation("AccountParentChild")
  auxiliaryRequirements AccountAuxiliaryRequirement[]
  openingBalances       OpeningBalance[]
  voucherLines          VoucherLine[]
  journalEntries        JournalEntry[]
  balances              AccountPeriodBalance[]
  bankStatements        BankStatement[]

  @@unique([accountSetId, code])
}

model AuxiliaryType {
  id           String   @id @default(uuid())
  accountSetId String
  code         String
  name         String
  category     String
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())

  accountSet   AccountSet                    @relation(fields: [accountSetId], references: [id])
  items        AuxiliaryItem[]
  requirements AccountAuxiliaryRequirement[]
  lineLinks    VoucherLineAuxiliary[]

  @@unique([accountSetId, code])
}

model AuxiliaryItem {
  id              String   @id @default(uuid())
  accountSetId    String
  auxiliaryTypeId String
  code            String
  name            String
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())

  accountSet    AccountSet             @relation(fields: [accountSetId], references: [id])
  auxiliaryType AuxiliaryType           @relation(fields: [auxiliaryTypeId], references: [id])
  lineLinks     VoucherLineAuxiliary[]

  @@unique([auxiliaryTypeId, code])
}

model AccountAuxiliaryRequirement {
  accountId       String
  auxiliaryTypeId String
  required        Boolean @default(true)

  account       ChartOfAccount @relation(fields: [accountId], references: [id])
  auxiliaryType AuxiliaryType  @relation(fields: [auxiliaryTypeId], references: [id])

  @@id([accountId, auxiliaryTypeId])
}

model OpeningBalance {
  id            String @id @default(uuid())
  accountId     String
  fiscalYear    Int
  periodNo      Int
  openingDebit  Float  @default(0)
  openingCredit Float  @default(0)

  account ChartOfAccount @relation(fields: [accountId], references: [id])

  @@unique([accountId, fiscalYear, periodNo])
}

model Voucher {
  id              String    @id @default(uuid())
  accountSetId    String
  fiscalYear      Int
  periodNo        Int
  periodId        String?
  voucherType     String    @default("J")
  voucherNo       String
  voucherDate     DateTime
  status          String
  summary         String?
  attachmentCount Int       @default(0)
  createdBy       String
  submittedBy     String?
  approvedBy      String?
  postedBy        String?
  postedAt        DateTime?
  sourceType      String    @default("manual")
  aiDraftId       String?
  version         Int       @default(1)
  revision        Int       @default(1)

  sourceModule        String?
  sourceDocumentType  String?
  sourceDocumentId    String?
  externalReferenceId String?
  businessPartnerId   String?
  settlementMethod    String?
  currencyId          String?
  exchangeRate        Float?  @default(1)

  accountSet     AccountSet             @relation(fields: [accountSetId], references: [id])
  period         AccountingPeriod?      @relation(fields: [periodId], references: [id])
  lines          VoucherLine[]
  logs           VoucherStatusLog[]
  attachmentLinks AttachmentLink[]
  journalEntries JournalEntry[]

  @@unique([accountSetId, fiscalYear, periodNo, voucherType, voucherNo])
}

model VoucherLine {
  id             String @id @default(uuid())
  voucherId      String
  lineNo         Int
  summary        String
  accountId      String
  debitAmount    Float  @default(0)
  creditAmount   Float  @default(0)
  currency       String @default("CNY")
  exchangeRate   Float  @default(1)
  originalAmount Float?
  quantity       Float?
  unitPrice      Float?

  voucher      Voucher                @relation(fields: [voucherId], references: [id])
  account      ChartOfAccount         @relation(fields: [accountId], references: [id])
  auxiliaries  VoucherLineAuxiliary[]
  journalEntry JournalEntry?

  @@unique([voucherId, lineNo])
}

model VoucherLineAuxiliary {
  voucherLineId   String
  auxiliaryTypeId String
  auxiliaryItemId String

  voucherLine   VoucherLine   @relation(fields: [voucherLineId], references: [id])
  auxiliaryType AuxiliaryType @relation(fields: [auxiliaryTypeId], references: [id])
  auxiliaryItem AuxiliaryItem @relation(fields: [auxiliaryItemId], references: [id])

  @@id([voucherLineId, auxiliaryTypeId])
}

model VoucherStatusLog {
  id         String   @id @default(uuid())
  voucherId  String
  action     String
  fromStatus String?
  toStatus   String
  actorId    String
  reason     String?
  createdAt  DateTime @default(now())

  voucher Voucher @relation(fields: [voucherId], references: [id])
}

model VoucherNumberSequence {
  id           String @id @default(uuid())
  accountSetId String
  fiscalYear   Int
  periodNo     Int
  voucherType  String
  currentNo    Int    @default(0)

  @@unique([accountSetId, fiscalYear, periodNo, voucherType])
}

model Attachment {
  id              String   @id @default(uuid())
  accountSetId    String
  fileName        String
  fileSize        Int
  mimeType        String
  storageProvider String
  storageKey      String
  hash            String
  status          String
  uploadedBy      String
  uploadedAt      DateTime @default(now())

  accountSet AccountSet       @relation(fields: [accountSetId], references: [id])
  links      AttachmentLink[]
}

model AttachmentLink {
  attachmentId String
  objectType   String
  objectId     String
  voucherId    String?
  linkedAt     DateTime @default(now())

  attachment Attachment @relation(fields: [attachmentId], references: [id])
  voucher    Voucher?   @relation(fields: [voucherId], references: [id])

  @@id([attachmentId, objectType, objectId])
}

model PostingBatch {
  id           String   @id @default(uuid())
  accountSetId String
  fiscalYear   Int
  periodNo     Int
  status       String
  voucherCount Int
  postedBy     String
  postedAt     DateTime @default(now())

  accountSet     AccountSet      @relation(fields: [accountSetId], references: [id])
  journalEntries JournalEntry[]
}

model JournalEntry {
  id                    String   @id @default(uuid())
  accountSetId          String
  voucherId             String
  voucherLineId         String   @unique
  fiscalYear            Int
  periodNo              Int
  entryDate             DateTime
  accountId             String
  summary               String
  debitAmount           Float    @default(0)
  creditAmount          Float    @default(0)
  auxiliarySnapshotJson String?
  postedBatchId         String

  accountSet  AccountSet     @relation(fields: [accountSetId], references: [id])
  voucher     Voucher        @relation(fields: [voucherId], references: [id])
  voucherLine VoucherLine    @relation(fields: [voucherLineId], references: [id])
  account     ChartOfAccount @relation(fields: [accountId], references: [id])
  batch       PostingBatch   @relation(fields: [postedBatchId], references: [id])
}

model AccountPeriodBalance {
  id                String @id @default(uuid())
  accountSetId      String
  fiscalYear        Int
  periodNo          Int
  accountId         String
  openingDebit      Float  @default(0)
  openingCredit     Float  @default(0)
  periodDebit       Float  @default(0)
  periodCredit      Float  @default(0)
  cumulativeDebit   Float  @default(0)
  cumulativeCredit  Float  @default(0)
  closingDebit      Float  @default(0)
  closingCredit     Float  @default(0)

  accountSet AccountSet     @relation(fields: [accountSetId], references: [id])
  account    ChartOfAccount @relation(fields: [accountId], references: [id])

  @@unique([accountSetId, fiscalYear, periodNo, accountId])
}

model BankStatement {
  id              String   @id @default(uuid())
  accountSetId    String
  bankAccountId   String
  transactionDate DateTime
  description     String
  amount          Float
  balance         Float?
  status          String   @default("unreconciled")

  accountSet AccountSet     @relation(fields: [accountSetId], references: [id])
  bankAccount ChartOfAccount @relation(fields: [bankAccountId], references: [id])
}

model BankReconciliationRule {
  id           String   @id @default(uuid())
  accountSetId String
  name         String
  matchPattern String
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())

  accountSet AccountSet @relation(fields: [accountSetId], references: [id])
}

model BankReconciliation {
  id           String   @id @default(uuid())
  accountSetId String
  fiscalYear   Int
  periodNo     Int
  status       String
  createdBy    String
  createdAt    DateTime @default(now())

  accountSet AccountSet @relation(fields: [accountSetId], references: [id])
}

model AuditLog {
  id           String   @id @default(uuid())
  accountSetId String?
  actorId      String
  action       String
  objectType   String
  objectId     String
  beforeJson   String?
  afterJson    String?
  traceId      String?
  occurredAt   DateTime @default(now())

  accountSet AccountSet? @relation(fields: [accountSetId], references: [id])
}

model Partner {
  id               String   @id @default(uuid())
  accountSetId     String
  partnerType      String
  code             String
  name             String
  taxRate          Float    @default(0)
  creditLimit      Float    @default(0)
  paymentTerms     String?
  settlementMethod String?
  isEnabled        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  accountSet AccountSet @relation(fields: [accountSetId], references: [id])
  purchaseOrders   PurchaseOrder[]   @relation("PurchaseOrderSupplier")
  salesOrders      SalesOrder[]      @relation("SalesOrderCustomer")
  purchaseReceipts PurchaseReceipt[] @relation("PurchaseReceiptSupplier")
  salesDeliveries  SalesDelivery[]   @relation("SalesDeliveryCustomer")
  purchaseInvoices PurchaseInvoice[] @relation("PurchaseInvoiceSupplier")
  salesInvoices    SalesInvoice[]    @relation("SalesInvoiceCustomer")
  counterpartyLedgerEntries CounterpartyLedgerEntry[]
  paymentRequests   PaymentRequest[]  @relation("PaymentRequestSupplier")
  supplierPayments  SupplierPayment[] @relation("SupplierPaymentSupplier")
  customerReceipts  CustomerReceipt[] @relation("CustomerReceiptCustomer")
  collectionPlans   CollectionPlan[]  @relation("CollectionPlanCustomer")
  apSettlements     ApSettlement[]    @relation("ApSettlementSupplier")

  @@unique([accountSetId, code])
  @@index([accountSetId, partnerType])
}

model PurchaseOrder {
  id           String   @id @default(uuid())
  accountSetId String
  supplierId   String
  orderNo      String
  orderDate    DateTime
  totalAmount  Float    @default(0)
  status       String   @default("draft")
  currency     String   @default("CNY")
  exchangeRate Float    @default(1)
  createdBy    String
  submittedBy  String?
  approvedBy   String?
  closedBy     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accountSet AccountSet @relation(fields: [accountSetId], references: [id])
  supplier   Partner    @relation("PurchaseOrderSupplier", fields: [supplierId], references: [id])
  lines      PurchaseOrderLine[]
  receipts   PurchaseReceipt[]

  @@unique([accountSetId, orderNo])
  @@index([accountSetId, status])
  @@index([supplierId])
}

model PurchaseOrderLine {
  id                String @id @default(uuid())
  purchaseOrderId   String
  lineNo            Int
  itemCode          String
  itemName          String
  quantity          Float
  unitPrice         Float
  taxRate           Float  @default(0)
  taxAmount         Float  @default(0)
  totalAmount       Float  @default(0)
  receivedQuantity  Float  @default(0)
  invoicedQuantity  Float  @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  receiptLines  PurchaseReceiptLine[]
  purchaseInvoiceLines PurchaseInvoiceLine[]

  @@unique([purchaseOrderId, lineNo])
}

model SalesOrder {
  id           String   @id @default(uuid())
  accountSetId String
  customerId   String
  orderNo      String
  orderDate    DateTime
  totalAmount  Float    @default(0)
  status       String   @default("draft")
  currency     String   @default("CNY")
  exchangeRate Float    @default(1)
  createdBy    String
  submittedBy  String?
  approvedBy   String?
  closedBy     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accountSet AccountSet @relation(fields: [accountSetId], references: [id])
  customer   Partner    @relation("SalesOrderCustomer", fields: [customerId], references: [id])
  lines      SalesOrderLine[]
  deliveries SalesDelivery[]

  @@unique([accountSetId, orderNo])
  @@index([accountSetId, status])
  @@index([customerId])
}

model SalesOrderLine {
  id               String @id @default(uuid())
  salesOrderId     String
  lineNo           Int
  itemCode         String
  itemName         String
  quantity         Float
  unitPrice        Float
  taxRate          Float  @default(0)
  taxAmount        Float  @default(0)
  totalAmount      Float  @default(0)
  shippedQuantity  Float  @default(0)
  invoicedQuantity Float  @default(0)

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])
  deliveryLines SalesDeliveryLine[]
  salesInvoiceLines SalesInvoiceLine[]

  @@unique([salesOrderId, lineNo])
}

model PurchaseReceipt {
  id               String   @id @default(uuid())
  accountSetId     String
  purchaseOrderId  String
  supplierId       String
  receiptNo        String
  receiptDate      DateTime
  status           String   @default("approved")
  totalQuantity    Float    @default(0)
  createdBy        String
  evidenceRefsJson String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  accountSet    AccountSet            @relation(fields: [accountSetId], references: [id])
  purchaseOrder PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id])
  supplier      Partner               @relation("PurchaseReceiptSupplier", fields: [supplierId], references: [id])
  lines         PurchaseReceiptLine[]
  invoices      PurchaseInvoice[]

  @@unique([accountSetId, receiptNo])
  @@index([purchaseOrderId])
  @@index([supplierId])
}

model PurchaseReceiptLine {
  id                  String @id @default(uuid())
  purchaseReceiptId   String
  purchaseOrderLineId String
  lineNo              Int
  itemCode            String
  itemName            String
  quantity            Float

  purchaseReceipt   PurchaseReceipt   @relation(fields: [purchaseReceiptId], references: [id])
  purchaseOrderLine PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id])

  @@unique([purchaseReceiptId, lineNo])
}

model SalesDelivery {
  id               String   @id @default(uuid())
  accountSetId     String
  salesOrderId     String
  customerId       String
  deliveryNo       String
  deliveryDate     DateTime
  status           String   @default("approved")
  totalQuantity    Float    @default(0)
  createdBy        String
  evidenceRefsJson String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  accountSet AccountSet          @relation(fields: [accountSetId], references: [id])
  salesOrder SalesOrder          @relation(fields: [salesOrderId], references: [id])
  customer   Partner             @relation("SalesDeliveryCustomer", fields: [customerId], references: [id])
  lines      SalesDeliveryLine[]
  invoices   SalesInvoice[]

  @@unique([accountSetId, deliveryNo])
  @@index([salesOrderId])
  @@index([customerId])
}

model SalesDeliveryLine {
  id               String @id @default(uuid())
  salesDeliveryId  String
  salesOrderLineId String
  lineNo           Int
  itemCode         String
  itemName         String
  quantity         Float

  salesDelivery  SalesDelivery @relation(fields: [salesDeliveryId], references: [id])
  salesOrderLine SalesOrderLine @relation(fields: [salesOrderLineId], references: [id])

  @@unique([salesDeliveryId, lineNo])
}

model PurchaseInvoice {
  id                  String   @id @default(uuid())
  accountSetId        String
  purchaseReceiptId   String
  supplierId          String
  invoiceNo           String
  externalInvoiceNo   String?
  invoiceDate         DateTime
  dueDate             DateTime?
  invoiceSource       String   @default("manual")
  status              String   @default("confirmed")
  totalAmount         Float    @default(0)
  taxAmount           Float    @default(0)
  payableAmount       Float    @default(0)
  paidAmount          Float    @default(0)
  settledAmount       Float    @default(0)
  estimatedDifference Float    @default(0)
  glVoucherId         String?
  createdBy           String
  evidenceRefsJson    String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  accountSet      AccountSet             @relation(fields: [accountSetId], references: [id])
  purchaseReceipt PurchaseReceipt        @relation(fields: [purchaseReceiptId], references: [id])
  supplier        Partner                @relation("PurchaseInvoiceSupplier", fields: [supplierId], references: [id])
  lines           PurchaseInvoiceLine[]

  @@unique([accountSetId, invoiceNo])
  @@index([purchaseReceiptId])
  @@index([supplierId])
}

model PurchaseInvoiceLine {
  id                  String @id @default(uuid())
  purchaseInvoiceId   String
  purchaseOrderLineId String
  lineNo              Int
  itemCode            String
  itemName            String
  quantity            Float
  unitPrice           Float
  taxRate             Float  @default(0)
  taxAmount           Float  @default(0)
  totalAmount         Float  @default(0)

  purchaseInvoice  PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id])
  purchaseOrderLine PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id])

  @@unique([purchaseInvoiceId, lineNo])
}

model SalesInvoice {
  id                String   @id @default(uuid())
  accountSetId      String
  salesDeliveryId   String
  customerId        String
  invoiceNo         String
  externalInvoiceNo String?
  invoiceDate       DateTime
  dueDate           DateTime?
  invoiceSource     String   @default("manual")
  status            String   @default("confirmed")
  totalAmount       Float    @default(0)
  taxAmount         Float    @default(0)
  receivableAmount  Float    @default(0)
  receivedAmount    Float    @default(0)
  settledAmount     Float    @default(0)
  glVoucherId       String?
  createdBy         String
  evidenceRefsJson  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  accountSet    AccountSet         @relation(fields: [accountSetId], references: [id])
  salesDelivery SalesDelivery      @relation(fields: [salesDeliveryId], references: [id])
  customer      Partner            @relation("SalesInvoiceCustomer", fields: [customerId], references: [id])
  lines         SalesInvoiceLine[]

  @@unique([accountSetId, invoiceNo])
  @@index([salesDeliveryId])
  @@index([customerId])
}

model SalesInvoiceLine {
  id               String @id @default(uuid())
  salesInvoiceId   String
  salesOrderLineId String
  lineNo           Int
  itemCode         String
  itemName         String
  quantity         Float
  unitPrice        Float
  taxRate          Float  @default(0)
  taxAmount        Float  @default(0)
  totalAmount      Float  @default(0)

  salesInvoice  SalesInvoice @relation(fields: [salesInvoiceId], references: [id])
  salesOrderLine SalesOrderLine @relation(fields: [salesOrderLineId], references: [id])

  @@unique([salesInvoiceId, lineNo])
}

model CounterpartyLedgerEntry {
  id                 String   @id @default(uuid())
  accountSetId       String
  partnerId          String
  direction          String
  sourceType         String
  sourceId           String
  sourceNo           String
  documentDate       DateTime
  dueDate            DateTime?
  originalAmount     Float    @default(0)
  settledAmount      Float    @default(0)
  remainingAmount    Float    @default(0)
  status             String   @default("open")
  glAccountCode      String
  auxiliaryType      String
  auxiliaryPartnerId String
  isPaymentBlocked   Boolean  @default(false)
  paymentBlockReason String?
  createdBy          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  accountSet AccountSet @relation(fields: [accountSetId], references: [id])
  partner    Partner    @relation(fields: [partnerId], references: [id])
  paymentRequests  PaymentRequest[]
  supplierPayments SupplierPayment[]
  customerReceipts CustomerReceipt[]
  collectionPlan   CollectionPlan?
  apSettlements    ApSettlement[]

  @@unique([sourceType, sourceId])
  @@index([accountSetId, direction, status])
  @@index([partnerId])
  @@index([dueDate])
}

model PaymentRequest {
  id                        String   @id @default(uuid())
  accountSetId              String
  counterpartyLedgerEntryId String
  supplierId                String
  requestNo                 String
  requestDate               DateTime
  plannedPaymentDate        DateTime?
  requestedAmount           Float    @default(0)
  status                    String   @default("pending_approval")
  requestedBy               String
  approvedBy                String?
  approvedAt                DateTime?
  approvalComment           String?
  paymentMethod             String?
  bankAccountCode           String
  evidenceRefsJson          String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  accountSet              AccountSet              @relation(fields: [accountSetId], references: [id])
  counterpartyLedgerEntry CounterpartyLedgerEntry @relation(fields: [counterpartyLedgerEntryId], references: [id])
  supplier                Partner                 @relation("PaymentRequestSupplier", fields: [supplierId], references: [id])
  supplierPayments        SupplierPayment[]

  @@unique([accountSetId, requestNo])
  @@index([accountSetId, status])
  @@index([counterpartyLedgerEntryId])
  @@index([supplierId])
}

model SupplierPayment {
  id                        String   @id @default(uuid())
  accountSetId              String
  paymentRequestId          String
  counterpartyLedgerEntryId String
  supplierId                String
  paymentNo                 String
  paymentDate               DateTime
  paidAmount                Float    @default(0)
  status                    String   @default("paid")
  paidBy                    String
  paymentMethod             String?
  bankAccountCode           String
  glVoucherId               String?
  evidenceRefsJson          String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  accountSet              AccountSet              @relation(fields: [accountSetId], references: [id])
  paymentRequest          PaymentRequest          @relation(fields: [paymentRequestId], references: [id])
  counterpartyLedgerEntry CounterpartyLedgerEntry @relation(fields: [counterpartyLedgerEntryId], references: [id])
  supplier                Partner                 @relation("SupplierPaymentSupplier", fields: [supplierId], references: [id])
  apSettlements           ApSettlement[]

  @@unique([accountSetId, paymentNo])
  @@index([accountSetId, status])
  @@index([paymentRequestId])
  @@index([supplierId])
}

model CustomerReceipt {
  id                        String   @id @default(uuid())
  accountSetId              String
  counterpartyLedgerEntryId String?
  customerId                String
  receiptNo                 String
  receiptDate               DateTime
  receiptType               String   @default("receipt")
  receivedAmount            Float    @default(0)
  status                    String   @default("received")
  receivedBy                String
  receiptMethod             String?
  bankAccountCode           String
  glVoucherId               String?
  evidenceRefsJson          String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  accountSet              AccountSet               @relation(fields: [accountSetId], references: [id])
  counterpartyLedgerEntry CounterpartyLedgerEntry? @relation(fields: [counterpartyLedgerEntryId], references: [id])
  customer                Partner                  @relation("CustomerReceiptCustomer", fields: [customerId], references: [id])

  @@unique([accountSetId, receiptNo])
  @@index([accountSetId, status])
  @@index([customerId])
  @@index([counterpartyLedgerEntryId])
}

model ApSettlement {
  id                        String   @id @default(uuid())
  accountSetId              String
  supplierId                String
  counterpartyLedgerEntryId String
  supplierPaymentId         String?
  settlementNo              String
  settlementDate            DateTime
  settlementType            String
  settledAmount             Float    @default(0)
  differenceAmount          Float    @default(0)
  differenceReason          String?
  status                    String   @default("settled")
  createdBy                 String
  evidenceRefsJson          String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  accountSet              AccountSet              @relation(fields: [accountSetId], references: [id])
  supplier                Partner                 @relation("ApSettlementSupplier", fields: [supplierId], references: [id])
  counterpartyLedgerEntry CounterpartyLedgerEntry @relation(fields: [counterpartyLedgerEntryId], references: [id])
  supplierPayment         SupplierPayment?        @relation(fields: [supplierPaymentId], references: [id])

  @@unique([accountSetId, settlementNo])
  @@index([accountSetId, status])
  @@index([counterpartyLedgerEntryId])
  @@index([supplierId])
  @@index([supplierPaymentId])
}

model CollectionPlan {
  id                        String   @id @default(uuid())
  accountSetId              String
  counterpartyLedgerEntryId String?
  customerId                String
  sourceNo                  String
  plannedReceiptDate        DateTime
  plannedAmount             Float    @default(0)
  status                    String   @default("planned")
  createdBy                 String
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  accountSet              AccountSet               @relation(fields: [accountSetId], references: [id])
  counterpartyLedgerEntry CounterpartyLedgerEntry? @relation(fields: [counterpartyLedgerEntryId], references: [id])
  customer                Partner                  @relation("CollectionPlanCustomer", fields: [customerId], references: [id])

  @@unique([counterpartyLedgerEntryId])
  @@index([accountSetId, status])
  @@index([customerId])
  @@index([plannedReceiptDate])
}
